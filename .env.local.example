# ─────────────────────────────────────────
# MongoDB Atlas (free tier — mongodb.com/atlas)
# ─────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/eventpass?retryWrites=true&w=majority

# ─────────────────────────────────────────
# Resend Email (free — resend.com)
# ─────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=passes@yourdomain.com
RESEND_FROM_NAME=Event Pass System

# ─────────────────────────────────────────
# Cloudinary (free — cloudinary.com)
# ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────
# Auth & Security
# ─────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars
STAFF_PIN=1234
ADMIN_EMAIL=admin@yourevent.com
ADMIN_PASSWORD=changeme123

# ─────────────────────────────────────────
# App Config
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_EVENT_NAME=TechSummit 2025
NEXT_PUBLIC_EVENT_DATE=2025-12-15
NEXT_PUBLIC_EVENT_VENUE=Hall A, Convention Centre, New Delhi
